# Copy to `.env` (or `secrets.env`) and fill in.
# Both filenames are loaded by the scripts; .env takes precedence.

OPENAI_API_KEY=sk-...

# Optional: override model (defaults to gpt-5.4-mini)
# OPENAI_MODEL=gpt-5.4-mini

# Optional: override dataset root (defaults to ../../../final_dataset relative to this file).
# Absolute path to the directory that holds `cosmos-drive-dreams/`, `cosmos-predict1/`, ...
# LOCAL_DATASET_ROOT=/home/matthieu/Documents/Projet de master/final_dataset
